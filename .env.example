# =============================================================================
# HarnessAgent — Environment Variables Example
# Copy to .env and fill in real values before running.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider Keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default model to use when no explicit model is provided
DEFAULT_MODEL=claude-sonnet-4-6

# -----------------------------------------------------------------------------
# Vector Store
# backend: chroma | qdrant | weaviate
# -----------------------------------------------------------------------------
VECTOR_BACKEND=chroma
CHROMA_PATH=/data/chroma
QDRANT_URL=http://localhost:6333
WEAVIATE_URL=http://localhost:8080

# Embedding model (sentence-transformers compatible name)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# -----------------------------------------------------------------------------
# Graph Store
# backend: networkx | neo4j
# -----------------------------------------------------------------------------
GRAPH_BACKEND=networkx
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=harnesspassword

# -----------------------------------------------------------------------------
# Redis (session store, rate limiter, LLM cache, task queue)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# MLflow Experiment Tracking
# -----------------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=harness-agent

# -----------------------------------------------------------------------------
# OpenTelemetry (OTLP gRPC endpoint)
# -----------------------------------------------------------------------------
OTEL_EXPORTER_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=harness-agent

# -----------------------------------------------------------------------------
# Agent Workspace
# Base directory for per-run sandboxed workspaces
# -----------------------------------------------------------------------------
WORKSPACE_BASE_PATH=/workspaces

# -----------------------------------------------------------------------------
# Hermes Self-Healing Agent
# -----------------------------------------------------------------------------
HERMES_AUTO_APPLY=false
HERMES_INTERVAL_SECONDS=3600.0
HERMES_MIN_ERRORS_TO_TRIGGER=5
HERMES_PATCH_SCORE_THRESHOLD=0.7

# -----------------------------------------------------------------------------
# Auth & Security
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-in-production-use-a-256bit-random-string

# -----------------------------------------------------------------------------
# Budgets & Rate Limits
# -----------------------------------------------------------------------------
COST_BUDGET_USD_PER_TENANT=100.0
RATE_LIMIT_RPM=60

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
ENVIRONMENT=dev
LOG_LEVEL=INFO
WORKER_CONCURRENCY=4

# -----------------------------------------------------------------------------
# External APIs (used by MCP servers)
# -----------------------------------------------------------------------------
BRAVE_API_KEY=BSAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/codex
